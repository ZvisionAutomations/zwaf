# ZWAF — Zvision WhatsApp Agent Framework
# Copie para .env.{tenant_id} e preencha com os valores reais

# ─── Ambiente ───────────────────────────────────────────────
ENV=production
ZWAF_TENANTS=livia-raiz-vital,caio-alpha-pulse

# API Key para autenticação do webhook (gerada aleatoriamente)
ZWAF_API_KEYS=sua-chave-api-aqui

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zwaf:senha@postgres:5432/zwaf_raiz_vital
POSTGRES_USER=zwaf
POSTGRES_PASSWORD=senha
POSTGRES_DB=zwaf_raiz_vital

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...  # Opcional — fallback para Gemini

# ─── Evolution API (WhatsApp) ───────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=sua-chave-evolution
EVOLUTION_POSTGRES_DB=evolution_raiz_vital

# Numeros WhatsApp - um por instancia Evolution
# WA_NUMBER_1 / WA_INSTANCE_1 = Livia (New Woman)
WA_NUMBER_1=5511999990001
WA_INSTANCE_1=livia-raiz-vital-1

# WA_NUMBER_2 / WA_INSTANCE_2 = Caio (Alpha Pulse)
WA_NUMBER_2=5511999990002
WA_INSTANCE_2=caio-alpha-pulse-1

# Webhook global da Evolution so aponta para um tenant.
# Para dois chips/instancias, configure webhook por instancia quando possivel.
EVOLUTION_WEBHOOK_TENANT=livia-raiz-vital

# Transcricao de audio WhatsApp (Groq Whisper)
TRANSCRIPTION_PROVIDER=groq
TRANSCRIPTION_FALLBACK_PROVIDER=disabled
TRANSCRIPTION_LANGUAGE=pt
TRANSCRIPTION_TIMEOUT_SECONDS=20
TRANSCRIPTION_MAX_BYTES=26214400
TRANSCRIPTION_ALLOWED_MIME_TYPES=audio/ogg,audio/opus,audio/mpeg,audio/mp4,audio/webm,audio/wav
# Allowlist opcional (CSV de hosts) para download de midia por URL. Vazio = sem
# restricao por hostname; IPs privados/loopback/link-local sao sempre bloqueados (SSRF).
TRANSCRIPTION_URL_ALLOWED_HOSTS=
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Relatorio diario Raiz Vital
REPORT_WA_DEST_NUMBER=  # Número privado do Fernando para relatório diário
CAIO_PERSONAL_WA_NUMBER=
INITIAL_STOCK_NEW_WOMAN=510
INITIAL_STOCK_ALPHA_PULSE=275

# Data de início do warm-up (formato: YYYY-MM-DD)
WA_WARMUP_START_DATE=2026-05-23

# Asaas
ASAAS_API_KEY=asaas_api_key_aqui
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_AUTH_TOKEN=webhook-token-aqui
ASAAS_USER_AGENT=zwaf-raiz-vital
ASAAS_RETURN_URL=https://raiz-vital.com.br/pagamento
ASAAS_COMPLETION_URL=https://raiz-vital.com.br/pagamento/confirmado
ASAAS_DEFAULT_CUSTOMER_CPF_CNPJ=

# SuperFrete (frete/etiqueta/rastreio)
# Token gerado no painel de integracoes da SuperFrete.
# Sandbox: https://sandbox.superfrete.com/#/integrations
# Producao: https://web.superfrete.com/#/integrations
SUPERFRETE_TOKEN=
# Sandbox: https://sandbox.superfrete.com
# Producao: https://api.superfrete.com
SUPERFRETE_BASE_URL=https://sandbox.superfrete.com
# Obrigatorio pela SuperFrete: Nome da aplicacao/versao (email tecnico).
SUPERFRETE_USER_AGENT=ZWAF Raiz Vital/1.0 (tecnico@seu-dominio.com.br)
# Secret token configurado no webhook app da SuperFrete para validar X-ME-Signature (HMAC-SHA256).
SUPERFRETE_WEBHOOK_SECRET=
# Apenas dev/local. Em staging/producao mantenha false e configure SUPERFRETE_WEBHOOK_SECRET.
SUPERFRETE_ALLOW_UNSIGNED_WEBHOOKS=false
# Mantem go-live em frete manual. So mude para true quando houver saldo e aprovacao operacional.
SUPERFRETE_AUTO_CHECKOUT_ENABLED=false
SUPERFRETE_SERVICES=1,2,17
SUPERFRETE_TIMEOUT_SECONDS=10

# Remetente usado para cotacao/etiqueta. Preencher no servidor, sem PII real no Git.
SUPERFRETE_FROM_NAME=Loja Raiz Vital
SUPERFRETE_FROM_ADDRESS=
SUPERFRETE_FROM_NUMBER=
SUPERFRETE_FROM_COMPLEMENT=
SUPERFRETE_FROM_DISTRICT=
SUPERFRETE_FROM_CITY=
SUPERFRETE_FROM_STATE=
SUPERFRETE_FROM_POSTAL_CODE=
SUPERFRETE_FROM_DOCUMENT=

# Pacote default para MVP; ajuste na VPS conforme embalagem real.
SUPERFRETE_PACKAGE_HEIGHT_CM=6
SUPERFRETE_PACKAGE_WIDTH_CM=16
SUPERFRETE_PACKAGE_LENGTH_CM=24
SUPERFRETE_PACKAGE_UNIT_WEIGHT_KG=0.3

# ─── Escalação ──────────────────────────────────────────────
ESCALATION_PHONE=+5511980142484   # Fernando — responsável Raiz Vital

# ─── Segurança / PII (Story 027) ────────────────────────────
# Chave Fernet (32 bytes, url-safe base64) para criptografar CPF/CNPJ e endereço.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SEM esta chave o checkout real FALHA de propósito (não persiste PII em claro).
ZWAF_PII_FERNET_KEY=
# Salt para hash de documento/identificadores (dedupe, auditoria, traces). Valor aleatório longo.
ZWAF_PII_HASH_SALT=

# ─── Observabilidade ────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # principal (SDK atual)
LANGFUSE_HOST=https://cloud.langfuse.com       # legado/compat

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317  # Opcional

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=https://app.raiz-vital.com.br

# Public HTTPS domains (Caddy reverse proxy)
# Examples:
# ZWAF_PUBLIC_DOMAIN=api.raiz-vital.com.br
# EVOLUTION_PUBLIC_DOMAIN=evolution.raiz-vital.com.br
ZWAF_PUBLIC_DOMAIN=api.seu-dominio.com.br
EVOLUTION_PUBLIC_DOMAIN=evolution.seu-dominio.com.br

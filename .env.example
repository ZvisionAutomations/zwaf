# ZWAF — Zvision WhatsApp Agent Framework
# Copie para .env.{tenant_id} e preencha com os valores reais

# ─── Ambiente ───────────────────────────────────────────────
ENV=production
ZWAF_TENANTS=livia-raiz-vital

# API Key para autenticação do webhook (gerada aleatoriamente)
ZWAF_API_KEYS=sua-chave-api-aqui

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zwaf:senha@postgres:5432/zwaf_livia
POSTGRES_USER=zwaf
POSTGRES_PASSWORD=senha
POSTGRES_DB=zwaf_livia

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...  # Opcional — fallback para Gemini

# ─── Evolution API (WhatsApp) ───────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=sua-chave-evolution

# Números WhatsApp — um por instância Evolution
WA_NUMBER_1=5511999990001
WA_INSTANCE_1=livia-raiz-vital-1

# WA_NUMBER_2 e WA_INSTANCE_2 — adicionar quando disponíveis

# Relatorio diario Sofia
REPORT_WA_DEST_NUMBER=  # Número privado do Fernando para relatório diário
CAIO_PERSONAL_WA_NUMBER=
INITIAL_STOCK_NEW_WOMAN=510
INITIAL_STOCK_ALPHA_PULSE=275

# Data de início do warm-up (formato: YYYY-MM-DD)
WA_WARMUP_START_DATE=2026-05-23

# ─── Abacate Pay ────────────────────────────────────────────
ABACATE_PAY_KEY=abacate_live_...
ABACATE_PAY_WEBHOOK_SECRET=webhook-secret-aqui
ABACATE_PAY_RETURN_URL=https://raiz-vital.com.br/pagamento
ABACATE_PAY_COMPLETION_URL=https://raiz-vital.com.br/pagamento/confirmado

# ─── Escalação ──────────────────────────────────────────────
ESCALATION_PHONE=+5511980142484   # Fernando — responsável Raiz Vital

# ─── Observabilidade ────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317  # Opcional

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=https://app.raiz-vital.com.br

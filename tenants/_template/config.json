{
  "_comment": "Copie esta pasta para tenants/{novo-tenant-id}/ e ajuste os valores. Remova _comment.",
  "tenant_id": "TENANT_ID_AQUI",
  "agent_name": "NOME_DO_AGENTE",
  "brand_name": "NOME_DA_MARCA",
  "llm": {
    "default_model": "gpt-4o-mini",
    "strong_model": "gpt-4o",
    "temperature": 0.7
  },
  "whatsapp": {
    "phone_numbers": [
      {"number": "${WA_NUMBER_1}", "instance": "${WA_INSTANCE_1}"}
    ],
    "evolution_api_url": "${EVOLUTION_API_URL}",
    "evolution_api_key": "${EVOLUTION_API_KEY}",
    "messages_per_minute": 12,
    "typing_simulation": {
      "enabled": true,
      "min_ms": 1000,
      "max_ms": 5000,
      "chars_per_second": 50,
      "jitter_ms": 0
    },
    "send_text_delay_ms": null,
    "warm_up_mode": false,
    "warm_up_start_date": null
  },
  "router": {
    "keywords": {
      "recompra": ["pedir de novo", "comprar de novo", "renovar", "recompra", "repor", "mais um"],
      "suporte": ["problema", "não chegou", "defeito", "reclamação", "reembolso", "cancelar", "devolução", "rastrear", "prazo"],
      "cobranca": ["pix", "boleto", "pagamento", "pagar", "não consigo pagar", "link expirou", "link não funciona"],
      "vendedor": ["quero comprar", "quero adquirir", "me interessa", "como funciona", "qual o preço", "valor"]
    },
    "default_agent": "vendedor"
  },
  "payment": {
    "provider": "asaas",
    "api_key": "${ASAAS_API_KEY}",
    "base_url": "${ASAAS_BASE_URL}",
    "webhook_auth_token": "${ASAAS_WEBHOOK_AUTH_TOKEN}",
    "user_agent": "${ASAAS_USER_AGENT}",
    "return_url": "${ASAAS_RETURN_URL}",
    "completion_url": "${ASAAS_COMPLETION_URL}",
    "default_customer_cpf_cnpj": "${ASAAS_DEFAULT_CUSTOMER_CPF_CNPJ}",
    "billing_type": "PIX",
    "products": {}
  },
  "escalation": {
    "phone": "${ESCALATION_PHONE}",
    "name": "Responsável"
  },
  "database_url": "${DATABASE_URL}",
  "redis_url": "${REDIS_URL}"
}

{
  "tenant_id": "livia-raiz-vital",
  "agent_name": "Lívia",
  "brand_name": "Raiz Vital",
  "language": "pt-BR",

  "llm": {
    "primary": "gpt-4o-mini",
    "fallback": "gemini-1.5-flash",
    "temperature": 0.7
  },

  "whatsapp": {
    "evolution_api_url": "${EVOLUTION_API_URL}",
    "evolution_api_key": "${EVOLUTION_API_KEY}",
    "phone_numbers": [
      {"number": "${WA_NUMBER_1}", "instance": "${WA_INSTANCE_1}"}
    ],
    "_note": "Chip confirmado: +5511967318916. Expandir para mais chips quando disponíveis.",
    "warm_up_mode": true,
    "warm_up_start_date": "${WA_WARMUP_START_DATE}",
    "messages_per_minute": 10,
    "typing_simulation": {
      "enabled": true,
      "min_ms": 1000,
      "max_ms": 5000,
      "chars_per_second": 50,
      "jitter_ms": 0
    },
    "send_text_delay_ms": null
  },

  "payment": {
    "provider": "asaas",
    "api_key": "${ASAAS_API_KEY}",
    "base_url": "${ASAAS_BASE_URL}",
    "webhook_auth_token": "${ASAAS_WEBHOOK_AUTH_TOKEN}",
    "user_agent": "${ASAAS_USER_AGENT}",
    "return_url": "${ASAAS_RETURN_URL}",
    "completion_url": "${ASAAS_COMPLETION_URL}",
    "default_customer_cpf_cnpj": "${ASAAS_DEFAULT_CUSTOMER_CPF_CNPJ}",
    "billing_type": "PIX",
    "products": {
      "new-woman-1": {"qty": 1, "price_cents_card": 18500, "price_cents_pix": 16590, "product_id": "nw-001"},
      "new-woman-2": {"qty": 2, "price_cents_card": 34790, "price_cents_pix": 33590, "product_id": "nw-002"},
      "new-woman-3": {"qty": 3, "price_cents_card": 44890, "price_cents_pix": 42290, "product_id": "nw-003"}
    },
    "free_shipping_above_cents": 30000,
    "_status": "Conta Asaas precisa ser criada/validada por Fernando. product_ids sao referencias internas."
  },

  "inventory": {
    "new-woman": {"initial_stock": 510}
  },

  "agents_enabled": ["vendedor", "recompra", "suporte", "cobranca", "fidelizacao"],

  "router": {
    "keywords": {
      "vendedor": ["quero comprar", "quanto custa", "como funciona", "tem desconto", "valor", "preço"],
      "recompra": ["quero pedir de novo", "acabou", "renovar", "segundo pote", "recompra"],
      "suporte": ["não chegou", "problema", "dúvida", "como tomar", "efeito", "reação"],
      "cobranca": ["pix", "boleto", "pagamento", "não consegui pagar", "link expirou"]
    },
    "fallback_llm": true
  },

  "fidelizacao": {
    "steps": [
      {"trigger": "product_received", "action": "ask_usage_doubts"},
      {"trigger": "days_after_delivery", "days": 15, "action": "ask_improvements"},
      {"trigger": "days_after_delivery", "days": 30, "action": "recompra_coupon_10pct"}
    ],
    "nps_enabled": true
  },

  "escalation": {
    "phone": "+5511980142484",
    "name": "Fernando",
    "hours": "commercial_only",
    "commercial_hours_brt": "08:00-18:00"
  },

  "lgpd": {
    "consent_required": true,
    "data_retention_days": 730
  }
}

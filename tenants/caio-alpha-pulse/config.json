{
  "tenant_id": "caio-alpha-pulse",
  "agent_name": "Caio",
  "brand_name": "Raiz Vital",
  "language": "pt-BR",

  "llm": {
    "primary": "gpt-4o-mini",
    "fallback": "gemini-1.5-flash",
    "temperature": 0.7
  },

  "whatsapp": {
    "evolution_api_url": "${EVOLUTION_API_URL}",
    "evolution_api_key": "${EVOLUTION_API_KEY}",
    "phone_numbers": [
      {"number": "${WA_NUMBER_2}", "instance": "${WA_INSTANCE_2}"}
    ],
    "_note": "Chip masculino Alpha Pulse. Configure WA_NUMBER_2 e WA_INSTANCE_2 no ambiente.",
    "warm_up_mode": true,
    "warm_up_start_date": "${WA_WARMUP_START_DATE}",
    "messages_per_minute": 10,
    "typing_simulation": {
      "enabled": true,
      "min_ms": 1000,
      "max_ms": 5000,
      "chars_per_second": 50,
      "jitter_ms": 0
    },
    "send_text_delay_ms": null
  },

  "payment": {
    "provider": "asaas",
    "api_key": "${ASAAS_API_KEY}",
    "base_url": "${ASAAS_BASE_URL}",
    "webhook_auth_token": "${ASAAS_WEBHOOK_AUTH_TOKEN}",
    "user_agent": "${ASAAS_USER_AGENT}",
    "return_url": "${ASAAS_RETURN_URL}",
    "completion_url": "${ASAAS_COMPLETION_URL}",
    "default_customer_cpf_cnpj": "${ASAAS_DEFAULT_CUSTOMER_CPF_CNPJ}",
    "billing_type": "PIX",
    "products": {
      "alpha-pulse": {
        "product_id": "ap-001",
        "pricing_model": "tiered_unit",
        "card_markup_pct": 0,
        "unit_price_tiers_pix_cents": [
          {"min_qty": 1, "max_qty": 1, "unit_cents": 14900},
          {"min_qty": 2, "max_qty": 4, "unit_cents": 12800},
          {"min_qty": 5, "max_qty": null, "unit_cents": 11990}
        ]
      }
    },
    "free_shipping_above_cents": 0,
    "_status": "Conta Asaas precisa ser criada/validada por Fernando. product_ids sao referencias internas."
  },

  "inventory": {
    "alpha-pulse": {"initial_stock": 275}
  },

  "agents_enabled": ["vendedor", "recompra", "suporte", "cobranca", "fidelizacao"],

  "router": {
    "keywords": {
      "vendedor": ["quero comprar", "quanto custa", "como funciona", "tem desconto", "valor", "preco", "preço"],
      "recompra": ["quero pedir de novo", "acabou", "renovar", "segundo frasco", "recompra"],
      "suporte": ["nao chegou", "não chegou", "problema", "duvida", "dúvida", "como tomar", "efeito", "reacao", "reação"],
      "cobranca": ["pix", "boleto", "pagamento", "nao consegui pagar", "não consegui pagar", "link expirou"]
    },
    "fallback_llm": true
  },

  "fidelizacao": {
    "steps": [
      {"trigger": "product_received", "action": "ask_usage_doubts"},
      {"trigger": "days_after_delivery", "days": 15, "action": "ask_improvements"},
      {"trigger": "days_after_delivery", "days": 30, "action": "recompra_coupon_10pct"}
    ],
    "nps_enabled": true
  },

  "escalation": {
    "phone": "+5511980142484",
    "name": "Fernando",
    "hours": "commercial_only",
    "commercial_hours_brt": "08:00-18:00"
  },

  "lgpd": {
    "consent_required": true,
    "data_retention_days": 730
  }
}

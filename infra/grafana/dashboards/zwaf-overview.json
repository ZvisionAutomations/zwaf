{
  "title": "ZWAF Overview",
  "uid": "zwaf-overview",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Webhooks recebidos/min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{path=~\"/v1/webhook/.*\"}[1m]) * 60",
          "legendFormat": "{{tenant_id}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência P95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Roteamento por agente",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (agent) (zwaf_route_total)",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Erros 429 WhatsApp",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(zwaf_whatsapp_429_total[1h]))",
          "legendFormat": "429s na última hora"
        }
      ]
    },
    {
      "id": 5,
      "title": "Mensagens enviadas hoje",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(zwaf_messages_sent_total[24h]))",
          "legendFormat": "Total"
        }
      ]
    }
  ]
}
